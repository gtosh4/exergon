// The canonical Standard run — landing to launching the successor. This is the same scenario the
// e2e smoke test (`tests/standard_full_run.rs`) drives, and the baseline for balancing sweeps:
// copy it, change the `seed` or the research/build targets, and compare the printed milestones.
//
// Fixed content-graph choreography (deploy kit → earn early tiers → craft the processing economy)
// lives in `Scenario::run_standard`; only the knobs below are data. See crates/scenario-runner.
(
    name: "standard",
    seed: 0xE7E60007,

    // ResearchSpend target nodes by theme. Each list self-orders by the real tech graph, so order
    // here is only for readability.
    material_nodes: [
        "ore_extraction",
        "drone_recon",
        "basic_processing",
        "silicon_refining",
        "aluminum_extraction",
        "titanium_forming",
        "steel_alloying",
    ],
    engineering_nodes: [
        "advanced_processing",
        "resonite_engineering",
        "advanced_assembler",
        "fluxite_coil",
        "provisioning_module",
    ],
    discovery_nodes: [
        "exotic_processing",
        "precursor_survey",
        "synthesis_lab",
        "space_scanner",
        "cryophase_prospecting",
    ],
    synthesis_nodes: [
        "coolant_reclaim",
        "vitreite_synthesis",
        "exotic_fuel_refining",
        "successor_core",
        "successor_chassis",
        "successor_drive",
        "successor_sensor",
        "launch_site_assembly",
        "launch_successor",
    ],

    // The successor build list, mass-balanced from the successor tree. `launch_successor` has no
    // output item, so it is an explicit job the grind enqueues once the closure is earned.
    build_jobs: [
        ("crush_stone", 8),
        ("crush_aluminum", 6),
        ("smelt_metal__iron", 10),
        ("smelt_metal__copper", 18),
        ("smelt_metal__aluminum", 4),
        ("smelt_metal__titanium", 2),
        ("draw_metal__copper", 17),
        ("wash_aluminum", 2),
        ("make_circuit", 4),
        ("refine_silicon", 4),
        ("refine_fluxite", 4),
        ("synth_vitreite", 2),
        ("roll_iron_plate", 2),
        ("roll_aluminum_plate", 2),
        ("roll_titanium_plate", 1),
        ("form_silicon_chip", 4),
        ("make_resonite_circuit", 2),
        ("form_resonite_lattice", 1),
        ("make_fluxite_coil", 2),
        ("make_power_cell", 1),
        ("make_miner_kit", 1),
        ("make_generator_kit", 1),
        ("make_assembler_kit", 1),
        ("refine_exotic_fuel__raw", 20),
        ("make_successor_core", 1),
        ("make_successor_sensor", 1),
        ("make_successor_chassis", 1),
        ("make_successor_drive", 1),
        ("make_provisioning_module", 1),
        ("launch_successor", 1),
    ],

    max_secs: 40000.0,
)
